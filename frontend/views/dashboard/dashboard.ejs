<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-12">
        <div>
            <h1 class="text-3xl font-bold text-white">Welcome back, <%= user.name %>!</h1>
            <p class="text-gray-400 mt-1">Here's what's happening with your services today.</p>
        </div>
        <div class="mt-4 md:mt-0 flex space-x-4">
            <a href="/plans" class="bg-primary hover:bg-accent text-white px-6 py-2 rounded-lg font-semibold transition neon-glow">New Order</a>
            <a href="/tickets" class="bg-dark-lighter border border-gray-700 hover:border-primary text-white px-6 py-2 rounded-lg font-semibold transition">Open Ticket</a>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="bg-dark-lighter p-6 rounded-2xl border border-gray-800">
            <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path></svg>
                </div>
                <span class="text-xs font-bold text-blue-500 uppercase tracking-wider">Active Services</span>
            </div>
            <div class="text-3xl font-bold text-white"><%= activeServices %></div>
        </div>
        <div class="bg-dark-lighter p-6 rounded-2xl border border-gray-800">
            <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 bg-yellow-500/20 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </div>
                <span class="text-xs font-bold text-yellow-500 uppercase tracking-wider">Pending Invoices</span>
            </div>
            <div class="text-3xl font-bold text-white"><%= pendingInvoices %></div>
        </div>
        <div class="bg-dark-lighter p-6 rounded-2xl border border-gray-800">
            <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                </div>
                <span class="text-xs font-bold text-green-500 uppercase tracking-wider">Open Tickets</span>
            </div>
            <div class="text-3xl font-bold text-white"><%= openTickets %></div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Recent Services -->
        <div class="bg-dark-lighter rounded-2xl border border-gray-800 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-800 flex justify-between items-center">
                <h3 class="font-bold text-white">Active Services</h3>
                <a href="/dashboard/services" class="text-primary text-sm hover:underline">View All</a>
            </div>
            <div class="p-0">
                <% if (services.length > 0) { %>
                    <table class="w-full text-left">
                        <thead class="bg-dark text-gray-400 text-xs uppercase">
                            <tr>
                                <th class="px-6 py-3">Service</th>
                                <th class="px-6 py-3">Status</th>
                                <th class="px-6 py-3">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-800">
                            <% services.slice(0, 5).forEach(service => { %>
                                <tr class="hover:bg-dark/50 transition">
                                    <td class="px-6 py-4">
                                        <div class="font-medium text-white"><%= service.plan_name %></div>
                                        <div class="text-xs text-gray-500">Node: <%= service.node_id %></div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase <%= service.status === 'active' ? 'bg-green-500/20 text-green-500' : 'bg-yellow-500/20 text-yellow-500' %>">
                                            <%= service.status %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <a href="/servers/<%= service.id %>" class="text-primary hover:text-accent transition text-sm font-semibold">Manage</a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <div class="p-12 text-center text-gray-500">No active services found.</div>
                <% } %>
            </div>
        </div>

        <!-- Recent Invoices -->
        <div class="bg-dark-lighter rounded-2xl border border-gray-800 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-800 flex justify-between items-center">
                <h3 class="font-bold text-white">Recent Invoices</h3>
                <a href="/dashboard/invoices" class="text-primary text-sm hover:underline">View All</a>
            </div>
            <div class="p-0">
                <% if (invoices.length > 0) { %>
                    <table class="w-full text-left">
                        <thead class="bg-dark text-gray-400 text-xs uppercase">
                            <tr>
                                <th class="px-6 py-3">Invoice #</th>
                                <th class="px-6 py-3">Amount</th>
                                <th class="px-6 py-3">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-800">
                            <% invoices.slice(0, 5).forEach(invoice => { %>
                                <tr class="hover:bg-dark/50 transition">
                                    <td class="px-6 py-4 text-white">#<%= invoice.id %></td>
                                    <td class="px-6 py-4 text-white">$<%= invoice.amount %></td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase <%= invoice.status === 'paid' ? 'bg-green-500/20 text-green-500' : 'bg-red-500/20 text-red-500' %>">
                                            <%= invoice.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <div class="p-12 text-center text-gray-500">No invoices found.</div>
                <% } %>
            </div>
        </div>
    </div>
</div>
