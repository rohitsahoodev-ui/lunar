<header class="bg-dark-lighter border-b border-gray-800 sticky top-0 z-50">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
            <div class="flex items-center">
                <a href="/" class="flex items-center space-x-2">
                    <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center neon-glow">
                        <span class="text-white font-bold">L</span>
                    </div>
                    <span class="text-xl font-bold tracking-tight text-white">LunarHost</span>
                </a>
                <div class="hidden md:block ml-10 flex space-x-8">
                    <a href="/plans" class="text-gray-300 hover:text-primary transition">Pricing</a>
                    <a href="/features" class="text-gray-300 hover:text-primary transition">Features</a>
                    <a href="/locations" class="text-gray-300 hover:text-primary transition">Locations</a>
                    <a href="/status" class="text-gray-300 hover:text-primary transition">Status</a>
                </div>
            </div>
            <div class="flex items-center space-x-4">
                <% if (user) { %>
                    <a href="/dashboard" class="text-gray-300 hover:text-primary transition">Dashboard</a>
                    <a href="/auth/logout" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg transition">Logout</a>
                <% } else { %>
                    <a href="/auth/login" class="text-gray-300 hover:text-primary transition">Login</a>
                    <a href="/auth/register" class="bg-primary hover:bg-accent text-white px-4 py-2 rounded-lg transition neon-glow">Get Started</a>
                <% } %>
            </div>
        </div>
    </nav>
</header>
