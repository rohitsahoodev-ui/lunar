<div class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
                <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6">Get in <span class="text-primary">Touch</span></h1>
                <p class="text-xl text-gray-400 mb-10">Have questions? Our team is here to help you 24/7.</p>
                
                <div class="space-y-8">
                    <div class="flex items-start">
                        <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mr-6">
                            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-white font-bold mb-1">Email Us</h4>
                            <p class="text-gray-400">support@lunarhost.com</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mr-6">
                            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-white font-bold mb-1">Live Chat</h4>
                            <p class="text-gray-400">Available in your dashboard 24/7.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-dark-lighter p-10 rounded-3xl border border-gray-800 neon-glow">
                <form action="/contact" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">First Name</label>
                            <input type="text" required class="w-full px-4 py-3 border border-gray-700 rounded-xl bg-dark text-white focus:ring-primary focus:border-primary">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Last Name</label>
                            <input type="text" required class="w-full px-4 py-3 border border-gray-700 rounded-xl bg-dark text-white focus:ring-primary focus:border-primary">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-400 mb-1">Email Address</label>
                        <input type="email" required class="w-full px-4 py-3 border border-gray-700 rounded-xl bg-dark text-white focus:ring-primary focus:border-primary">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-400 mb-1">Message</label>
                        <textarea rows="4" required class="w-full px-4 py-3 border border-gray-700 rounded-xl bg-dark text-white focus:ring-primary focus:border-primary"></textarea>
                    </div>
                    <button type="submit" class="w-full bg-primary hover:bg-accent text-white py-4 rounded-xl font-bold transition neon-glow">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</div>
